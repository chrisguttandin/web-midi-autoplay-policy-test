{
    "author": "Christoph Guttandin",
    "bugs": {
        "url": "https://github.com/chrisguttandin/web-midi-autoplay-policy-test/issues"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "description": "A demo to test the Web MIDI Autoplay Policy.",
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "@commitlint/cli": "^21.2.0",
        "@commitlint/config-angular": "^21.2.0",
        "babel-loader": "^10.1.1",
        "commitizen": "^4.3.2",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^9.39.4",
        "eslint-config-holy-grail": "^63.0.3",
        "globals": "^17.7.0",
        "html-minifier": "^4.0.0",
        "htmlhint": "^1.9.2",
        "husky": "^9.1.7",
        "hyperlink": "^5.0.4",
        "lint-staged": "^17.0.8",
        "prettier": "^3.9.4",
        "rimraf": "^6.1.3",
        "webpack": "^5.108.4",
        "webpack-cli": "^7.1.0",
        "webpack-dev-server": "^6.0.0"
    },
    "homepage": "https://chrisguttandin.github.io/web-midi-autoplay-policy-test",
    "license": "MIT",
    "main": "src/index.html",
    "name": "web-midi-autoplay-policy-test",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/chrisguttandin/web-midi-autoplay-policy-test.git"
    },
    "scripts": {
        "build": "rimraf build/* && html-minifier --config-file config/html-minifier/config.json --file-ext html --input-dir src --output-dir build && npx webpack --config config/webpack/production.js",
        "lint": "npm run lint:config && npm run lint:src",
        "lint:config": "eslint --config config/eslint/config.mjs --ext .cjs --ext .js --ext .mjs --report-unused-disable-directives config/",
        "lint:src": "eslint --config config/eslint/src.mjs --ext .js --report-unused-disable-directives src/ && htmlhint --config config/htmlhint/document.json 'src/**/index.html'",
        "monitor": "npx webpack server --config config/webpack/development.js",
        "prepare": "husky",
        "test": "npm run lint"
    },
    "version": "1.0.20"
}
